generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AppConfig {
  key       String   @id
  value     String   @db.Text
  label     String?
  category  String?
  updatedAt DateTime @updatedAt
}

model ReportFormat {
  id          String         @id
  name        String         @db.Text
  description String?
  template    String         @db.Text
  config      Json
  isActive    Boolean        @default(true)
  sessions    RekapSession[]
}

model PriorityLink {
  id          BigInt   @id @default(autoincrement())
  keyword     String   @unique
  description String?  @db.Text
  priority    Int      @default(999)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Operator {
  id        BigInt         @id @default(autoincrement())
  waId      String         @unique
  createdAt DateTime       @default(now())
  sessions  RekapSession[]
}

model RekapSession {
  id          String       @id @default(uuid())
  operatorId  BigInt
  formatId    String
  title       String?      @db.Text
  dateRange   String?
  state       String       @default("draft")
  totalLinks  Int          @default(0)
  summaryJson Json?
  createdAt   DateTime     @default(now())
  completedAt DateTime?
  links       Link[]
  format      ReportFormat @relation(fields: [formatId], references: [id])
  operator    Operator     @relation(fields: [operatorId], references: [id])

  @@index([formatId], map: "RekapSession_formatId_fkey")
  @@index([operatorId], map: "RekapSession_operatorId_fkey")
}

model Platform {
  id     BigInt @id @default(autoincrement())
  name   String @unique
  domain Json?
  links  Link[]
}

model Unit {
  id    BigInt @id @default(autoincrement())
  name  String @unique
  type  String
  links Link[]
}

model Link {
  id         BigInt       @id @default(autoincrement())
  url        String       @db.Text
  sessionId  String
  platformId BigInt
  unitId     BigInt?
  isPriority Boolean      @default(false)
  createdAt  DateTime     @default(now())
  platform   Platform     @relation(fields: [platformId], references: [id])
  session    RekapSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  unit       Unit?        @relation(fields: [unitId], references: [id])

  @@index([platformId], map: "Link_platformId_fkey")
  @@index([sessionId], map: "Link_sessionId_fkey")
  @@index([unitId], map: "Link_unitId_fkey")
}

model User {
  id        BigInt   @id @default(autoincrement())
  username  String   @unique @db.VarChar(100)
  password  String   @db.Text
  email     String?  @unique @db.VarChar(255)
  role      String   @default("admin")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BaileysSession {
  id        String   @id
  value     String   @db.Text
  updatedAt DateTime
}

model CustomDocument {
  id        String   @id
  name      String
  paperSize String   @default("f4")
  orient    String   @default("landscape")
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime
}
